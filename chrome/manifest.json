{
  "manifest_version": 3,
  "name": "LOK extension",
  "version": "1.0.0",
  "description": "Téléchargement et clip de vidéos YouTube — copie de médias vers Premiere Pro",
  "icons": {
    "48": "icons/icon-48.svg",
    "96": "icons/icon-96.svg"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": { "48": "icons/icon-48.svg" },
    "default_title": "LOK extension"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "activeTab",
    "clipboardWrite",
    "nativeMessaging",
    "storage",
    "notifications",
    "contextMenus",
    "tabs"
  ],
  "host_permissions": [
    "*://www.youtube.com/*",
    "*://*/*"
  ]
}
